          {
            "id": "b2-u1-test-match-1",
            "sentence": "We think **B** that this new policy will benefit everyone involved.",
            "answer": "B – that this new policy will benefit everyone involved."
          },
          {
            "id": "b2-u1-test-match-2",
            "sentence": "The young athlete resembles **H** his grandfather — same build, same walk.",
            "answer": "H – his grandfather — same build, same walk."
          },
          {
            "id": "b2-u1-test-match-3",
            "sentence": "That dictionary belongs **F** to the school library, not to me.",
            "answer": "F – to the school library, not to me."
          },
          {
            "id": "b2-u1-test-match-4",
            "sentence": "The emergency kit contains **G** three sets of batteries and a charger.",
            "answer": "G – three sets of batteries and a charger."
          },
          {
            "id": "b2-u1-test-match-5",
            "sentence": "I now weigh **A** slightly less than I did before I started the diet.",
            "answer": "A – slightly less than I did before I started the diet."
          },
          {
            "id": "b2-u1-test-match-6",
            "sentence": "The garden smells **D** wonderful in the early morning.",
            "answer": "D – wonderful in the early morning."
          },
          {
            "id": "b2-u1-test-match-7",
            "sentence": "This project matters **E** a great deal to the local residents.",
            "answer": "E – a great deal to the local residents."
          },
          {
            "id": "b2-u1-test-match-8",
            "sentence": "I've been considering **C** whether to change careers at my age.",
            "answer": "C – whether to change careers at my age."
          }
        ],
        "interaction": {
          "formatType": "column_matching",
          "screenMode": "all_pairs_single_screen"
        }
