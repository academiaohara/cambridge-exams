    "cards": [
      {
        "id": "theory-card-1",
        "title": "a (indefinite article)",
        "subtitle": "a (indefinite article)",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "singular countable nouns that are not specific or not yet known to the listener: I'm looking for **a** good restaurant around here."
            ]
          }
        ]
      },
      {
        "id": "theory-card-2",
        "title": "an (indefinite article)",
        "subtitle": "an (indefinite article)",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "used instead of *a* when the following word begins with a vowel sound: She waited for **an** entire hour."
            ]
          },
          {
            "type": "remember_box",
            "title": "Be careful",
            "items": []
          }
        ]
      },
      {
        "id": "theory-card-3",
        "title": "the (definite article)",
        "subtitle": "the (definite article)",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "singular countable nouns (specific): Have you been to **the** new café on the high street?",
              "plural countable nouns (specific): Did you read **the** messages I sent you?",
              "uncountable nouns (specific): She handed **the** money to the cashier and walked out."
            ]
          }
        ]
      },
      {
        "id": "theory-card-4",
        "title": "No article (zero article)",
        "subtitle": "No article (zero article)",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "plural countable nouns (general): Smartphones have changed the way we communicate.",
              "uncountable nouns (general): Regular exercise is essential for good health."
            ]
          }
        ]
      },
      {
