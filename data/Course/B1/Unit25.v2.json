      },
      {
        "id": "theory-card-2",
        "title": "Too and enough",
        "subtitle": "Too and enough",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "comparison_table",
            "title": "Use",
            "headers": [
              "Use",
              "Example"
            ],
            "rows": [
              [
                "We use **too** to say that something is more than necessary or acceptable, with a negative effect.",
                "The coffee is **too hot** to drink right now."
              ],
              [
                "We use **enough** to say that there is the right amount of something, or to say there is not enough.",
                "She isn't **old enough** to get a driving licence."
              ]
            ]
          },
          {
            "type": "form_table",
            "title": "Form",
            "rows": [
              {
                "label": "",
