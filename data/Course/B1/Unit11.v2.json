    "cards": [
      {
        "id": "theory-card-1",
        "title": "The passive (continuous, perfect, past perfect, be going to, modals)",
        "subtitle": "The passive (continuous, perfect, past perfect, be going to, modals)",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "form_table",
            "title": "Form",
            "formula": "be in the correct tense + past participle",
            "rows": [
              {
                "label": "statement",
                "left": "The sandwiches **are being prepared**."
              },
              {
                "label": "negative",
                "left": "The sandwiches **aren't (are not) being prepared**."
              },
              {
                "label": "question",
                "left": "**Are** the sandwiches **being prepared**?"
              }
            ]
          },
          {
            "type": "comparison_table",
            "title": "Tense transformations (active → passive)",
            "headers": [
              "Tense / Structure",
              "Active",
              "Passive"
            ],
            "rows": [
              [
                "present continuous",
                "The chef is preparing the desserts.",
                "The desserts **are being prepared** by the chef."
              ],
              [
                "present perfect simple",
                "The school has organised the event.",
                "The event **has been organised** by the school."
              ],
              [
                "past continuous",
                "The workers were repairing the bridge.",
                "The bridge **was being repaired** by the workers."
              ],
              [
                "past perfect simple",
                "The police had closed the road.",
                "The road **had been closed** by the police."
              ],
              [
                "be going to",
                "They are going to build a new stadium.",
                "A new stadium **is going to be built**."
              ],
              [
                "modal (might)",
                "They might cancel the concert.",
                "The concert **might be cancelled**."
              ],
              [
                "modal (should)",
                "You should lock the doors.",
                "The doors **should be locked**."
              ],
              [
                "modal (must)",
                "Students must wear uniforms.",
                "Uniforms **must be worn** by students."
              ],
              [
                "modal (can)",
                "We can solve the problem easily.",
                "The problem **can be solved** easily."
              ]
            ]
          },
          {
            "type": "remember_box",
            "title": "Be careful",
            "items": [
              "Use **by** to introduce the person or thing that performs the action: The mural was painted **by** local artists.",
              "Use **with** to introduce the tool or instrument used: The bread was cut **with** a sharp knife.",
              "Leave out **by** or **with** when the agent or instrument is unknown or not relevant: The injured player was taken to hospital immediately."
            ]
          }
        ]
      }
    ]
  },
