    "cards": [
      {
        "id": "theory-card-1",
        "title": "-ing",
        "subtitle": "-ing",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "chips",
            "title": "Useful notes",
            "items": [
              "✓ She's thinking of **changing** her job."
            ]
          },
          {
            "type": "remember_box",
            "title": "Be careful",
            "items": [
              {
                "note": "Some phrases end with the preposition *to*. These phrases are also followed by the -ing form, not an infinitive."
              },
              {
                "correct": "I'm used **to getting** up early."
              },
              {
                "incorrect": "I'm used **to get** up early."
              },
              {
                "note": "The -ing form can also function as the subject of a sentence."
              },
              {
                "correct": "**Swimming** keeps you fit!"
              }
            ]
          }
        ]
      },
      {
        "id": "theory-card-2",
        "title": "Infinitive",
        "subtitle": "Infinitive",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "remember_box",
            "title": "Be careful",
            "items": [
              "Some verbs (let, make) are typically followed by an object + bare infinitive (without to).",
              "When make is used in the passive, it is followed by a full infinitive: The students were made to rewrite their essays.",
              "Some verbs can take either the infinitive alone or object + full infinitive: She needs him to explain the problem."
            ]
          }
        ]
      },
      {
        "id": "theory-card-3",
        "title": "-ing or infinitive",
        "subtitle": "-ing or infinitive",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "comparison_table",
            "title": "Meaning changes",
            "headers": [
              "Verb",
              "+ -ing",
              "+ full infinitive"
            ],
            "rows": [
              [
                "remember",
                "recall something that happened in the past",
                "not forget to carry out a planned task"
              ],
              [
                "forget",
                "be unable to recall a past event or action",
                "fail to do something that was planned"
              ],
              [
                "stop",
                "cease doing something permanently or for a time",
                "pause in order to do something else"
              ],
              [
                "try",
                "attempt something as an experiment or solution",
                "make an effort or attempt to do something"
              ]
            ]
          }
        ]
      }
    ]
  },
