    "exercises": [
      {
        "id": "b1-u1-ex-1",
        "type": "exercise",
        "exerciseType": "prompt_to_sentence",
        "exerciseTypeName": "Build the Sentence",
        "title": "A: Build the routine",
        "instructions": "Use the prompts to write complete present simple sentences.",
        "studentInstruction": "Write the full sentence.",
        "grammarFocus": "present simple for routines",
        "items": [
          {
            "id": "b1-u1-ex1-1",
            "prompt": {
              "subject": "Jake",
              "timeExpression": "every morning",
              "verbPhrase": "walk to school"
            },
            "displayPrompt": "Jake / every morning / walk to school",
            "answer": "Every morning, Jake walks to school.",
            "acceptedAnswers": [
              "Every morning, Jake walks to school.",
              "Jake walks to school every morning."
            ],
            "explanation": "Use the present simple for routines. Jake is a singular subject, so walk becomes walks."
          },
          {
            "id": "b1-u1-ex1-2",
            "prompt": {
              "subject": "Mia",
              "timeExpression": "usually",
              "verbPhrase": "drink tea for breakfast"
            },
            "displayPrompt": "Mia / usually / drink tea for breakfast",
            "answer": "Mia usually drinks tea for breakfast.",
            "acceptedAnswers": [
              "Mia usually drinks tea for breakfast."
            ],
            "explanation": "Usually goes before the main verb. Mia is singular, so drink becomes drinks."
          },
          {
            "id": "b1-u1-ex1-3",
            "prompt": {
              "subject": "Sara",
              "timeExpression": "after school / often",
              "verbPhrase": "do her homework in the library"
            },
            "displayPrompt": "Sara / after school / often / do her homework in the library",
            "answer": "After school, Sara often does her homework in the library.",
            "acceptedAnswers": [
              "After school, Sara often does her homework in the library.",
              "Sara often does her homework in the library after school."
            ],
            "explanation": "Often normally goes before the main verb. With Sara, use does, not do."
          },
          {
            "id": "b1-u1-ex1-4",
            "prompt": {
              "subject": "Lena",
              "timeExpression": "twice a month",
              "verbPhrase": "visit her grandparents"
            },
            "displayPrompt": "Lena / visit her grandparents / twice a month",
            "answer": "Lena visits her grandparents twice a month.",
            "acceptedAnswers": [
              "Lena visits her grandparents twice a month.",
              "Twice a month, Lena visits her grandparents."
            ],
            "explanation": "Twice a month shows a repeated habit. Lena is singular, so visit becomes visits."
          },
          {
            "id": "b1-u1-ex1-5",
            "prompt": {
              "subject": "Emma",
              "timeExpression": "never / on weekdays",
              "verbPhrase": "stay up late"
            },
            "displayPrompt": "Emma / never / stay up late / on weekdays",
            "answer": "Emma never stays up late on weekdays.",
            "acceptedAnswers": [
              "Emma never stays up late on weekdays."
            ],
            "explanation": "Never goes before the main verb. Emma is singular, so stay becomes stays."
          },
          {
            "id": "b1-u1-ex1-6",
            "prompt": {
              "subject": "Nora",
              "timeExpression": "every Saturday",
              "verbPhrase": "play basketball"
            },
            "displayPrompt": "Nora / play basketball / every Saturday",
            "answer": "Nora plays basketball every Saturday.",
            "acceptedAnswers": [
              "Nora plays basketball every Saturday.",
              "Every Saturday, Nora plays basketball."
            ],
            "explanation": "Every Saturday describes a routine. Nora is singular, so play becomes plays."
          }
        ]
      },
      {
        "id": "b1-u1-ex-2",
        "type": "exercise",
        "exerciseType": "gap_fill",
        "exerciseTypeName": "Complete the Gap",
        "title": "B: What is happening now?",
        "instructions": "Complete each sentence with the correct present continuous form of the verb.",
        "studentInstruction": "Type the missing form.",
        "grammarFocus": "present continuous",
        "items": [
          {
            "id": "b1-u1-ex2-1",
            "sentence": "Be quiet! The baby ...... .",
            "verbPrompt": "sleep",
            "answer": "is sleeping",
            "acceptedAnswers": [
              "is sleeping"
            ],
            "explanation": "Use the present continuous for something happening now. The baby is singular, so use is sleeping."
          },
          {
            "id": "b1-u1-ex2-2",
            "sentence": "We ...... the film because it's boring.",
            "verbPrompt": "not / watch",
            "answer": "aren't watching",
            "acceptedAnswers": [
              "aren't watching",
              "are not watching"
            ],
            "explanation": "Use the negative present continuous: subject + am/is/are + not + verb-ing. With we, use aren't watching."
          },
          {
            "id": "b1-u1-ex2-3",
            "sentence": "At the moment, Carla ...... for her science test.",
            "verbPrompt": "study",
            "answer": "is studying",
            "acceptedAnswers": [
              "is studying"
            ],
            "explanation": "At the moment tells us the action is happening now, so use is studying."
          },
          {
            "id": "b1-u1-ex2-4",
            "sentence": "Tom ...... with his cousins this week.",
            "verbPrompt": "stay",
            "answer": "is staying",
            "acceptedAnswers": [
              "is staying"
            ],
            "explanation": "This week describes a temporary situation, so the present continuous is natural."
          },
          {
            "id": "b1-u1-ex2-5",
            "sentence": "I ...... ! I'm serious!",
            "verbPrompt": "not / joke",
