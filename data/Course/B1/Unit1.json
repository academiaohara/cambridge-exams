  "block": 1,
  "unit": 1,
  "type": "grammar",
  "unitTitle": "Unit 1: Present simple, present continuous & stative verbs",
  "unitSubtitle": "Habits, actions happening now, and verbs that usually avoid continuous forms",
  "unitLevel": "B1",
  "unitFocus": [
    "present simple",
    "present continuous",
    "stative verbs",
    "frequency adverbs",
    "temporary situations",
    "habits and routines"
  ],
  "estimatedDurationMinutes": 25,
  "lessonStyle": "sune-play",
  "unitStructure": {
    "mode": "theory_then_practice_nodes",
    "theoryRequiredBeforePractice": true,
    "allowTheoryReviewFromPractice": true,
    "practiceNodesUseExerciseItemsAsContentBank": true
  },
  "theory": {
    "id": "b1-u1-theory",
    "title": "Learn the rule",
    "shortTitle": "Theory",
    "displayMode": "swipeable_cards",
    "completionRule": {
      "type": "view_all_cards",
      "required": true
    },
    "cards": [
      {
        "id": "b1-u1-theory-card-1",
        "title": "Present simple",
        "subtitle": "Habits and facts",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "form_table",
            "title": "Form",
            "rows": [
              {
                "label": "Positive",
                "left": "I / you / we / they play",
                "right": "he / she / it plays"
              },
              {
                "label": "Negative",
                "left": "I / you / we / they don't play",
                "right": "he / she / it doesn't play"
              },
              {
                "label": "Question",
                "left": "Do I / you / we / they play?",
                "right": "Does he / she / it play?"
              }
            ]
          },
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "Regular habits and routines",
              "Permanent or long-lasting situations",
              "Facts that are always true",
              "States, opinions and feelings"
            ]
          },
          {
            "type": "example_list",
            "title": "Examples",
            "items": [
              "Tom catches the bus every morning.",
              "My aunt lives in a small town.",
              "She loves Italian food.",
              "Water boils at 100 degrees Celsius."
            ]
          },
          {
            "type": "chips",
            "title": "Useful words",
            "items": [
              "always",
              "usually",
              "often",
              "sometimes",
              "rarely",
              "never",
              "every day",
              "twice a week",
              "once a month"
            ]
          },
          {
            "type": "remember_box",
            "title": "Remember",
            "items": [
              "Frequency adverbs usually come before the main verb.",
              "They come after the verb be."
            ],
            "examples": [
              "She usually walks to school.",
              "She is always early."
            ]
          }
        ]
      },
      {
        "id": "b1-u1-theory-card-2",
        "title": "Present continuous",
        "subtitle": "Now and temporary situations",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "form_table",
            "title": "Form",
            "rows": [
              {
                "label": "Positive",
                "left": "I am playing",
                "right": "he / she / it is playing; you / we / they are playing"
              },
              {
                "label": "Negative",
                "left": "I am not playing",
                "right": "he / she / it isn't playing; you / we / they aren't playing"
              },
              {
                "label": "Question",
                "left": "Am I playing?",
                "right": "Is he / she / it playing? Are you / we / they playing?"
              }
            ]
          },
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "Actions happening now",
              "Temporary situations",
              "Changing situations",
              "Annoying repeated actions with always"
            ]
          },
          {
            "type": "example_list",
            "title": "Examples",
            "items": [
              "Sam is talking on the phone right now.",
              "Lucy is staying with her grandparents this week.",
              "My sister is always leaving her clothes on the floor!"
            ]
          },
          {
            "type": "chips",
            "title": "Useful words",
            "items": [
              "now",
              "right now",
              "at the moment",
              "today",
              "this week",
              "these days"
            ]
          }
        ]
      },
      {
        "id": "b1-u1-theory-card-3",
        "title": "Stative verbs",
        "subtitle": "States, not actions",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "explanation",
            "title": "What are stative verbs?",
            "description": "Stative verbs describe states, feelings, opinions, senses or possession. We do not normally use them in continuous forms."
          },
          {
            "type": "correct_incorrect_examples",
            "title": "Compare",
            "correctExamples": [
              "I understand what you mean."
            ],
            "incorrectExamples": [
              "I am understanding what you mean."
            ]
          },
          {
            "type": "chips",
            "title": "Common stative verbs",
            "items": [
              "be",
              "believe",
              "belong to",
              "hate",
              "have",
              "know",
              "like",
              "love",
              "need",
              "prefer",
              "seem",
              "understand",
              "want"
            ]
          },
          {
            "type": "remember_box",
            "title": "Be careful",
            "description": "Some verbs can be stative or active depending on the meaning.",
            "examples": [
              "What do you think of this song? = opinion",
              "I'm thinking about changing schools. = considering"
            ]
          }
        ]
      }
    ]
  },
