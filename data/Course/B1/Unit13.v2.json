    "cards": [
      {
        "id": "theory-card-1",
        "title": "Countable nouns",
        "subtitle": "Countable nouns",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "explanation",
            "title": "Form",
            "description": "Countable nouns can be counted. They have both singular and plural forms and can be used with either a singular or plural verb."
          },
          {
            "type": "explanation",
            "title": "Useful notes",
            "description": "We use these words with countable nouns: **a, an, many, a few, one, two, ...**"
          },
          {
            "type": "remember_box",
            "title": "Be careful",
            "items": []
          }
        ]
      },
      {
        "id": "theory-card-2",
        "title": "Uncountable nouns",
        "subtitle": "Uncountable nouns",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "explanation",
            "title": "",
            "description": "Some nouns cannot be counted (uncountable nouns). They have no plural form and are used with a singular verb, even when they end in **-s**."
          },
          {
            "type": "comparison_table",
            "title": "Compare",
            "headers": [
              "Some uncountable nouns",
              "Example"
            ],
            "rows": [
              [
                "advice, bread, fruit, furniture, hair, homework, information, money, news, paper, rice, work",
                "My **money** is in my wallet.\nYour **hair** is really long!\nThe **news** was a complete shock."
              ]
            ]
          },
          {
            "type": "explanation",
            "title": "",
            "description": "We use these words with uncountable nouns:"
          },
          {
            "type": "explanation",
            "title": "",
            "description": "We use these words with both countable and uncountable nouns:"
          },
          {
            "type": "explanation",
            "title": "",
            "description": "We can use **any** in questions and negative statements with both uncountable nouns and plural countable nouns:"
          },
          {
            "type": "remember_box",
            "title": "Be careful",
            "items": [
              {
                "note": "Plural uncountable nouns"
              },
              "Some uncountable nouns are grammatically plural and go with a plural verb. Watch out for these:",
              {
                "correct": "**clothes** — Your clean **clothes** are on the bed."
              },
              {
                "correct": "**jeans** — Your new **jeans** look great!"
              },
              {
                "note": "Dual-meaning nouns"
              },
              "Certain nouns can be uncountable in one sense and countable in another.",
              {
                "correct": "Can you get some **paper** at the supermarket? (= sheets of paper for writing)"
              },
              {
                "correct": "Can you get a **paper** at the supermarket? (= a newspaper)"
              }
            ]
          }
        ]
      }
    ]
  },
