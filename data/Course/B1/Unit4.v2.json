    "cards": [
      {
        "id": "theory-card-1",
        "title": "Present perfect simple",
        "subtitle": "Present perfect simple",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "form_table",
            "title": "Form",
            "formula": "have/has + past participle",
            "rows": [
              {
                "label": "statement",
                "left": "I/you/we/they **have ('ve) learned** ...",
                "right": "He/she/it **has ('s) learned** ..."
              },
              {
                "label": "negative",
                "left": "I/you/we/they **have not (haven't) learned** ...",
                "right": "He/she/it **has not (hasn't) learned** ..."
              },
              {
                "label": "question",
                "left": "**Have** I/you/we/they **learned** ...?",
                "right": "**Has** he/she/it **learned** ...?"
              }
            ]
          },
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "Situations or states that began in the past and continue now",
              "Actions that happened at some point in the past when the exact time isn't given",
              "Past actions whose results affect the present moment"
            ]
          },
          {
            "type": "example_list",
            "title": "Examples",
            "items": [
              "Mr Torres **has taught** at this school for over ten years.",
              "I **have never tried** sushi — this will be the first time!",
              "We can't go out — Mum **has lost** her keys."
            ]
          },
          {
            "type": "chips",
            "title": "Useful notes",
            "items": [
              "for",
              "since",
              "just",
              "already",
              "yet",
              "ever",
              "never",
              "It's the first time"
            ]
          },
          {
            "type": "remember_box",
            "title": "Be careful",
            "items": [
              "We don't use the present perfect simple when we want to say **when** something happened in the past. We use the past simple: ✓ I **did** my homework **last night**.",
              "We don't use the past simple when we want to show that something happened before now or is still important now. We use the present perfect simple: ✓ I've **finished**! Can I go home now?",
              "Some verbs have irregular past participle forms."
            ]
          }
        ]
      },
      {
        "id": "theory-card-2",
        "title": "Present perfect continuous",
        "subtitle": "Present perfect continuous",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "form_table",
            "title": "Form",
            "formula": "have/has + been + -ing",
            "rows": [
              {
                "label": "statement",
                "left": "I/you/we/they **have ('ve) been studying** ...",
                "right": "He/she/it **has ('s) been studying** ..."
              },
              {
                "label": "negative",
                "left": "I/you/we/they **have not (haven't) been studying** ...",
                "right": "He/she/it **has not (hasn't) been studying** ..."
              },
              {
                "label": "question",
                "left": "**Have** I/you/we/they **been studying** ...?",
                "right": "**Has** he/she/it **been studying** ...?"
              }
            ]
          },
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "Activities that have been going on up to the present or have just stopped"
            ]
          },
          {
            "type": "example_list",
            "title": "Examples",
            "items": [
              "I **have been waiting** here for half an hour — where have you been?",
              "She looks exhausted because she **has been running**."
            ]
          },
          {
            "type": "comparison_table",
            "title": "Useful notes",
            "headers": [
              "Key word",
              "Example"
            ],
            "rows": [
              [
                "for",
                "I've been learning English **for** over three years."
              ],
              [
                "since",
                "He's been learning Chinese **since** 2004."
              ],
              [
                "just",
                "I've **just** been reading the school newspaper."
              ]
            ]
          },
          {
            "type": "remember_box",
            "title": "Be careful",
            "items": [
              "The present perfect simple often emphasises the result of an action: ✓ She's **written** an article for the school newspaper. (= She's finished it.)",
              "The present perfect continuous often emphasises the action, and the time spent on the action, rather than the result: ✓ She's **been writing** an article for the school newspaper. (= She's started, but she hasn't finished it yet.)"
            ]
          }
        ]
      }
    ]
  },
