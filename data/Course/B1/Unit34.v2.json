    "cards": [
      {
        "id": "theory-card-1",
        "title": "Verbs without an object",
        "subtitle": "Verbs without an object",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "explanation",
            "title": "Use",
            "description": "Certain verbs only require a subject to form a complete sentence. No object is needed."
          }
        ]
      },
      {
        "id": "theory-card-2",
        "title": "Verbs with one object",
        "subtitle": "Verbs with one object",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "explanation",
            "title": "Use",
            "description": "A large number of verbs take a single object after them to complete their meaning."
          }
        ]
      },
      {
        "id": "theory-card-3",
        "title": "Verbs with two objects",
        "subtitle": "Verbs with two objects",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "explanation",
            "title": "Use",
            "description": "Certain verbs can take two objects at the same time. One is the direct object (the thing) and the other is the indirect object (usually a person)."
          },
          {
            "type": "chips",
            "title": "Useful notes",
            "items": [
              "He sent a postcard **to** Maria.",
              "She bought a gift **for** her brother."
            ]
          },
          {
            "type": "explanation",
            "title": "",
            "description": "These verbs can also be used in the passive."
          },
          {
            "type": "remember_box",
            "title": "Be careful",
            "items": [
              "When the indirect object is placed before the direct object, do not add a preposition.",
              "Correct: She gave Leo the keys.",
              "Incorrect: She gave to Leo the keys."
            ]
          }
        ]
      }
    ]
  },
