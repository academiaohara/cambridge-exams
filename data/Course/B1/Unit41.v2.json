            ],
            "rows": [
              [
                "present simple",
                "The manager **has** her office **redecorated** every year."
              ],
              [
                "present continuous",
                "She **is having** the walls **painted** at the moment."
              ],
              [
                "present perfect simple",
                "She **has had** the carpet **replaced**."
              ],
              [
                "past simple",
                "She **had** the windows **cleaned** last week."
              ],
              [
                "past continuous",
                "She **was having** the computers **repaired** when I visited."
              ],
              [
                "past perfect simple",
                "She **had had** the furniture **rearranged**."
              ],
              [
                "will / would",
                "She **will have** a new sofa **delivered**. / She **would have** new curtains **put up**."
              ],
              [
                "be going to",
