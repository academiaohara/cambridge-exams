    "cards": [
      {
        "id": "theory-card-1",
        "title": "Present continuous",
        "subtitle": "Present continuous",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "form_table",
            "title": "Form",
            "rows": [
              {
                "label": "statement",
                "left": "I **am ('m) studying** ...",
                "right": "He/she/it **is ('s) studying** ... You/we/they **are ('re) studying** ..."
              },
              {
                "label": "negative",
                "left": "I **am not ('m not) studying** ...",
                "right": "He/she/it **is not (isn't / 's not) studying** ... You/we/they **are not (aren't / 're not) studying** ..."
              },
              {
                "label": "question",
                "left": "**Am** I **studying** ...?",
                "right": "**Is** he/she/it **studying** ...? **Are** you/we/they **studying** ...?"
              }
            ]
          },
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "Fixed future arrangements: We **'re meeting** our cousins on Saturday."
            ]
          },
          {
            "type": "remember_box",
            "title": "Be careful",
            "items": [
              "We use *be going to* for intentions that are not fully arranged yet. ✗ I **'m becoming** a pilot one day.",
              "We do not normally use the present continuous for predictions. ✗ I think it **'s snowing** tomorrow."
            ]
          }
        ]
      },
      {
        "id": "theory-card-2",
        "title": "will",
        "subtitle": "will",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "form_table",
            "title": "Form",
            "formula": "will + bare infinitive",
            "rows": [
              {
                "label": "statement",
                "left": "I/you/he/she/it/we/they **will ('ll) travel** ..."
              },
              {
                "label": "negative",
                "left": "I/you/he/she/it/we/they **will not (won't) travel** ..."
              },
              {
                "label": "question",
                "left": "**Will** I/you/he/she/it/we/they **travel** ...?"
              }
            ]
          },
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "Predictions and opinions: I think people **will live** longer in the future.",
              "Offers and promises: I **'ll help** you with your homework.",
              "Instant decisions: I'm thirsty — I **'ll get** some water."
            ]
          },
          {
            "type": "remember_box",
            "title": "Be careful",
            "items": [
              "Use *shall* for offers and suggestions with *I* and *we*: **Shall** we go now?",
              "We do not usually use *will* for planned arrangements."
            ]
          }
        ]
      },
      {
        "id": "theory-card-3",
        "title": "be going to",
        "subtitle": "be going to",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "form_table",
            "title": "Form",
            "formula": "be going to + bare infinitive",
            "rows": [
              {
                "label": "statement",
                "left": "I **am ('m) going to study** ...",
                "right": "He/she/it **is ('s) going to study** ... You/we/they **are ('re) going to study** ..."
              },
              {
                "label": "negative",
                "left": "I **am ('m) not going to study** ...",
                "right": "He/she/it **is not (isn't / 's not) going to study** ... You/we/they **are not (aren't / 're not) going to study** ..."
              },
              {
                "label": "question",
                "left": "**Am** I **going to study** ...?",
                "right": "**Is** he/she/it **going to study** ...? **Are** you/we/they **going to study** ...?"
              }
            ]
          },
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "Future intentions: She **'s going to learn** Japanese next year.",
              "Predictions based on evidence: Look at those clouds — it **'s going to rain**."
            ]
          }
        ]
      },
      {
        "id": "theory-card-4",
        "title": "Present simple",
        "subtitle": "Present simple",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "form_table",
            "title": "Form",
            "rows": [
              {
                "label": "statement",
                "left": "I/you/we/they **leave** ...",
                "right": "He/she/it **leaves** ..."
              },
              {
                "label": "negative",
                "left": "I/you/we/they **do not (don't) leave** ...",
                "right": "He/she/it **does not (doesn't) leave** ..."
              },
              {
                "label": "question",
                "left": "**Do** I/you/we/they **leave** ...?",
                "right": "**Does** he/she/it **leave** ...?"
              }
            ]
          },
          {
            "type": "bullet_list",
            "title": "Use",
            "items": [
              "Timetables and schedules: The train **arrives** at half past six."
            ]
          }
        ]
      }
    ]
