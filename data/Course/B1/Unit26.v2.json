    "cards": [
      {
        "id": "theory-card-1",
        "title": "Comparatives",
        "subtitle": "Comparatives",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "comparison_table",
            "title": "Use",
            "headers": [
              "Use",
              "Example"
            ],
            "rows": [
              [
                "To say that one person, thing or action differs from another",
                "The city centre is **more crowded than** the suburbs.\nCould you speak a little **more slowly**, please?"
              ]
            ]
          },
          {
            "type": "comparison_table",
            "title": "Form: adjectives",
            "headers": [
              "Type",
              "Rule",
              "Example"
            ],
            "rows": [
              [
                "one syllable",
                "adjective + -er",
                "tall → **taller**"
              ],
              [
                "one syllable ending in -e",
                "adjective + -r",
                "safe → **safer**"
              ],
              [
                "one syllable ending in vowel + consonant",
                "double last letter + -er",
                "hot → **hotter**"
              ],
              [
                "two syllables ending in -y",
                "-y → -ier",
                "happy → **happier**"
              ],
              [
                "two or more syllables",
                "more/less + adjective",
                "comfortable → **more/less comfortable**"
              ],
              [
                "irregular adjectives / quantifiers",
                "special form",
                "good → **better**, bad → **worse**, little → **less**, far → **farther/further**, many/much → **more**"
              ]
            ]
          },
          {
            "type": "comparison_table",
            "title": "Form: adverbs",
            "headers": [
              "Type",
              "Rule",
              "Example"
            ],
            "rows": [
              [
                "regular adverbs",
                "more/less + adverb",
                "quietly → **more/less quietly**"
              ],
              [
                "irregular adverbs",
                "special form",
                "well → **better**, badly → **worse**, early → **earlier**, near → **nearer**, late → **later**, fast → **faster**, far → **farther/further**"
              ]
            ]
          },
          {
            "type": "chips",
            "title": "Useful notes",
            "items": [
              "The comparative is usually followed by **than**: *This route is **longer than** the one we took before.*"
            ]
          }
        ]
      },
      {
        "id": "theory-card-2",
        "title": "Superlatives",
        "subtitle": "Superlatives",
        "cardType": "rule_card",
        "sections": [
          {
            "type": "comparison_table",
            "title": "Use",
            "headers": [
              "Use",
              "Example"
            ],
            "rows": [
              [
                "To identify the one member of a group that has the most or least of a quality",
                "This is **the most popular** café in the whole city.\nOf all the runners, she finished **the fastest**."
              ]
            ]
          },
          {
            "type": "comparison_table",
            "title": "Form: adjectives",
            "headers": [
              "Type",
              "Rule",
              "Example"
            ],
            "rows": [
              [
                "one syllable",
                "adjective + -est",
                "tall → **tallest**"
              ],
              [
                "one syllable ending in -e",
                "adjective + -st",
                "safe → **safest**"
              ],
              [
                "one syllable ending in vowel + consonant",
                "double last letter + -est",
                "hot → **hottest**"
              ],
              [
                "two syllables ending in -y",
                "-y → -iest",
                "happy → **happiest**"
              ],
              [
                "two or more syllables",
                "most/least + adjective",
                "comfortable → **most/least comfortable**"
              ],
              [
                "irregular adjectives / quantifiers",
                "special form",
                "good → **best**, bad → **worst**, little → **least**, far → **farthest/furthest**, many/much → **most**"
              ]
            ]
          },
          {
            "type": "comparison_table",
            "title": "Form: adverbs",
            "headers": [
              "Type",
              "Rule",
              "Example"
            ],
            "rows": [
              [
                "regular adverbs",
                "most/least + adverb",
                "quietly → **most/least quietly**"
              ],
              [
                "irregular adverbs",
                "special form",
                "well → **best**, badly → **worst**, early → **earliest**, near → **nearest**, late → **latest**, fast → **fastest**, far → **farthest/furthest**"
              ]
            ]
          },
          {
            "type": "chips",
            "title": "Useful notes",
            "items": [
              "We normally use **the** before a superlative: *That was **the most memorable** concert I've ever been to.*"
            ]
          }
        ]
      }
    ]
