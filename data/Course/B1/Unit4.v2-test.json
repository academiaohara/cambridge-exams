    "exercises": [
      {
        "id": "b1-u4-test-ex-standalone",
        "type": "exercise",
        "exerciseType": "mc_4_option",
        "exerciseTypeName": "Choose A, B, C or D",
        "title": "B: Choose the correct answer",
        "instructions": "Choose the correct answer.",
        "studentInstruction": "Tap the best option.",
        "items": [
          {
            "id": "b1-u4-test-ex-standalone-1",
            "displayMode": "standalone",
            "prompt": "...... here for a long time?",
            "options": [
              { "letter": "A", "text": "Have they worked" },
              { "letter": "B", "text": "Did they work" },
              { "letter": "C", "text": "Do they work" },
              { "letter": "D", "text": "Had they worked" }
            ],
            "answer": "A",
            "answerText": "Have they worked",
            "explanation": "For + period → present perfect.",
            "answerMode": "tap_letter_abcd",
            "formatType": "mc_4_option"
          },
          {
            "id": "b1-u4-test-ex-standalone-2",
            "displayMode": "standalone",
            "prompt": "We ...... to the zoo last weekend.",
            "options": [
              { "letter": "A", "text": "have gone" },
              { "letter": "B", "text": "went" },
              { "letter": "C", "text": "go" },
              { "letter": "D", "text": "had gone" }
            ],
            "answer": "B",
            "answerText": "went",
            "explanation": "Last weekend is a finished past time → past simple.",
            "answerMode": "tap_letter_abcd",
            "formatType": "mc_4_option"
          }
        ],
        "interaction": {
          "formatType": "mc_4_option",
          "shuffleOptions": true,
          "showLetters": true
        }
      },
      {
        "id": "b1-u4-test-ex-passage",
        "type": "exercise",
        "exerciseType": "mc_4_option",
        "exerciseTypeName": "Multiple Choice Passage",
        "title": "E: Multiple choice passage",
        "instructions": "Choose the correct answer: A, B, C or D.",
        "studentInstruction": "Tap each numbered gap and choose an option.",
        "displayMode": "passage",
        "questions": [
          {
            "sentence": "She (1) ...... on an urgent assignment this week, so she won't be available until Monday.",
            "gaps": [
              {
                "num": 1,
                "options": [
                  "A works",
                  "B is working",
                  "C has worked",
                  "D has been working"
                ],
                "answer": "B"
              }
            ]
          },
          {
            "sentence": "Water (2) ...... at a lower temperature at high altitudes than it does at sea level.",
            "gaps": [
              {
                "num": 2,
                "options": [
                  "A is boiling",
                  "B has boiled",
                  "C boils",
                  "D has been boiling"
                ],
                "answer": "C"
              }
            ]
          },
          {
            "sentence": "The charity (3) ...... over fifty thousand pounds already this year.",
            "gaps": [
              {
                "num": 3,
                "options": [
                  "A raised",
                  "B raises",
                  "C is raising",
                  "D has raised"
                ],
                "answer": "D"
              }
            ]
          },
          {
            "sentence": "I'm worried — the wind (4) ...... stronger. The forecast mentioned a possible storm.",
            "gaps": [
              {
                "num": 4,
                "options": [
                  "A gets",
                  "B got",
                  "C is getting",
                  "D has got"
                ],
                "answer": "C"
              }
            ]
          }
        ],
        "interaction": {
          "formatType": "mc_4_option",
          "passageScreenMode": "all_gaps_single_screen",
          "gapPillStyle": "numbered_slot"
        }
      }
    ]
  }
